<!-- FILE: Views/Shipment/Create.cshtml -->
@model ShipmentTrackers.Models.Shipment
@{
    ViewData["Title"] = "Create Shipment";
}

<h2 class="mb-4">📦 Create New Shipment</h2>

<div class="card shadow-sm" style="max-width:600px">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="SenderName" class="form-label"></label>
                <input asp-for="SenderName" class="form-control" placeholder="Enter sender's name" />
                <span asp-validation-for="SenderName" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ReceiverName" class="form-label"></label>
                <input asp-for="ReceiverName" class="form-control" placeholder="Enter receiver's name" />
                <span asp-validation-for="ReceiverName" class="text-danger small"></span>
            </div>
            <div class="row">
                <div class="col mb-3">
                    <label asp-for="Origin" class="form-label"></label>
                    <input asp-for="Origin" class="form-control" placeholder="From city" />
                    <span asp-validation-for="Origin" class="text-danger small"></span>
                </div>
                <div class="col mb-3">
                    <label asp-for="Destination" class="form-label"></label>
                    <input asp-for="Destination" class="form-control" placeholder="To city" />
                    <span asp-validation-for="Destination" class="text-danger small"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Weight" class="form-label"></label>
                <input asp-for="Weight" type="number" step="0.1" class="form-control" placeholder="e.g. 2.5" />
            </div>
            <button type="submit" class="btn btn-primary w-100">Generate Tracking ID & Save</button>
        </form>
    </div>
</div>